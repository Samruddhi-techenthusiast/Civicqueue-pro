# Copy this file to .env and fill in real values.
# `npm run dev` / `npm start` will refuse to boot if any REQUIRED variable is missing
# (see src/config/validateEnv.js), and will refuse to boot in production if the JWT
# secrets are still left as obvious placeholders.

# ── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB (REQUIRED) ───────────────────────────────────
# Local: brew services start mongodb-community  (or run `mongod`)
# Or use MongoDB Atlas free tier: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb://localhost:27017/civicqueue

# ── JWT (REQUIRED) ───────────────────────────────────────
# Generate real random secrets, e.g.:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Never reuse the same value for both secrets, and never commit real values.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRE=30m
JWT_REFRESH_EXPIRE=7d

# ── Redis (OPTIONAL) ─────────────────────────────────────
# Set to false if Redis is not installed — app runs fine without it, it just skips
# caching and access-token blacklisting on logout.
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Rate Limiting ────────────────────────────────────────
# NOTE: rate limiting is currently DISABLED in app.js/auth.routes.js (no 429s during
# testing/deployment, per project decision). These vars are inert right now — kept
# here in case you want to re-enable middlewares/rateLimit.middleware.js later.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── URLs ─────────────────────────────────────────────────
# Comma-separated list of allowed browser origins for CORS + where QR codes point.
# In production this MUST be your real deployed frontend URL(s) — there is no
# wildcard fallback.
FRONTEND_URL=http://localhost:5173,http://localhost:3000
QR_BASE_URL=http://localhost:3000/verify

# ── Logging ──────────────────────────────────────────────
# Use "info" or "warn" in production; "debug" is noisy and fine for local dev only.
LOG_LEVEL=debug
LOG_DIR=logs

# ── Email (OPTIONAL — leave blank to disable) ────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
