# Frontend environment — Vite reads these at build/dev time

# API URL — leave as /api/v1 to use the Vite dev proxy (recommended for local dev)
# This avoids CORS issues entirely since requests go through Vite's proxy to localhost:5000
VITE_API_URL=/api/v1

# Socket.IO URL — must be direct (not proxied) for WebSocket connections
VITE_SOCKET_URL=http://localhost:5000
