# Copy this file to .env and adjust for your setup.

# API URL — leave as /api/v1 to use the Vite dev proxy (recommended for local dev,
# avoids CORS entirely). In production, point this at your deployed backend, e.g.
# https://civicqueue-api.onrender.com/api/v1
VITE_API_URL=/api/v1

# Socket.IO URL — must be a direct URL (not proxied) for WebSocket connections.
# In production, point this at your deployed backend's origin (no /api/v1 suffix).
VITE_SOCKET_URL=http://localhost:5000
