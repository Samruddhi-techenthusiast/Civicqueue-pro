# ── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB (required) ───────────────────────────────────
MONGO_URI=mongodb://localhost:27017/civicqueue

# ── JWT (required — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_ACCESS_SECRET=replace_with_64_char_secret
JWT_REFRESH_SECRET=replace_with_different_64_char_secret
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ── Redis (OPTIONAL — set REDIS_ENABLED=false to skip entirely) ──
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── URLs ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
QR_BASE_URL=http://localhost:3000/verify

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=debug
LOG_DIR=logs
